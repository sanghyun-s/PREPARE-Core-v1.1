# PREPARE Core v1.0 — environment template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in your values. Never commit `.env`.
#
#   cp .env.example .env
#
# The .env file is loaded automatically by server.py via python-dotenv.

# Anthropic API key — required for AI-assisted and Multi-agent engines.
# Rule-based engine works without this key.
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
